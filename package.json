{
  "name": "helpme-desktop",
  "version": "1.0.0",
  "description": "HelpMe - AI Screen Assistant",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "predev": "node -e \"try{require('child_process').execSync('npx kill-port 5173',{stdio:'pipe'})}catch(e){}\"",
    "dev": "concurrently --kill-others-on-fail -n \"VITE,ELECTRON\" -c \"cyan,green\" \"vite --port 5173 --strictPort\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "openai": "^4.77.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "katex": "^0.16.11",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.5.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.1.0",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.helpme.desktop",
    "productName": "HelpMe",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*", "node_modules/**/*", "package.json"],
    "win": { "target": "nsis" }
  }
}
